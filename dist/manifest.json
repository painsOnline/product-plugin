{
  "manifest_version": 3,
  "name": "商品一键导入助手",
  "version": "0.1.0",
  "description": "自动从1688/淘宝抓取商品数据，一键导入到街顺后台",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://detail.1688.com/*",
    "https://item.taobao.com/*",
    "https://s.waisongbang.com/*",
    "https://app.xinqianmao.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "商品导入助手"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://detail.1688.com/offer/*"],
      "js": ["content-1688.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://item.taobao.com/item.htm*"],
      "js": ["content-taobao.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://s.waisongbang.com/*"],
      "js": ["content-jieshun.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
