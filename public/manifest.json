{
  "manifest_version": 3,
  "name": "鑫钱搬手",
  "version": "0.1.0",
  "description": "自动从1688/淘宝抓取商品数据，一键导入到街顺后台",
  "icons": {
    "16": "static/xinqianbanshou_icon.png",
    "48": "static/xinqianbanshou_icon.png",
    "128": "static/xinqianbanshou_icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://detail.1688.com/*",
    "https://item.taobao.com/*",
    "https://s.waisongbang.com/*",
    "https://app.xinqianmao.com/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "鑫钱搬手",
    "default_icon": "static/xinqianbanshou_icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["content-1688.js", "content-taobao.js", "content-jieshun.js", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
